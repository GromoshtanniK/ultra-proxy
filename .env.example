# Copy to ".env" and edit. Apply changes with:
#   scripts/render-config.sh   (or  powershell -File scripts/render-config.ps1)

# PORT and ADDR the explicit HTTP/SOCKS proxy listens on (point apps at <LISTEN_ADDR>:<PROXY_PORT>).
LISTEN_ADDR=0.0.0.0
PROXY_PORT=8888

# ===== External HTTPS (TLS) proxy =====
# Matched hosts/subnets are routed through this proxy; everything else is direct.
EXT_SERVER=vpn.proxy.com
EXT_PORT=443
EXT_USERNAME=
EXT_PASSWORD=
# Set to true if the external proxy requires TLS (HTTPS proxy, not plain HTTP).
EXT_TLS=false
# Set to true ONLY if the external proxy uses a self-signed / untrusted cert.
EXT_TLS_INSECURE=false

# DNS resolver type: https (DoH, port 443), tls (DoT, port 853), udp, tcp, local
# "https" is most firewall-friendly; "local" uses the container's system resolver.
DNS_TYPE=https
DNS_SERVER=1.1.1.1

# trace | debug | info | warn | error
LOG_LEVEL=info

# tun interface address
TUN_ADDR=192.168.30.1/30
